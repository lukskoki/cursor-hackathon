# Kopiraj u .env i popuni iz Firebase Console → Project settings → Your apps → Web app.
# Expo učitava samo varijable koje počinju s EXPO_PUBLIC_

EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
EXPO_PUBLIC_FIREBASE_MEASUREMENT_ID=

# Google prijava — samo Web client ID (Google Cloud → Credentials → OAuth 2.0 → Web application)
# Redirect u Expo Go ide preko https://auth.expo.io/... (taj URI dodaj u Web client → Authorized redirect URIs).
# exp://... NE smije u Google — ne radi u Web polju.
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=

# Opcionalno: ako redirect_uri mismatch — u __DEV__ konzoli kopiraj "Stvarni redirect_uri" i zalijepi ovdje + u Google.
# EXPO_PUBLIC_EXPO_AUTH_REDIRECT_URI=https://auth.expo.io/@tvojuser/voluntee
